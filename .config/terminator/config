[global_config]
  tab_position = bottom
  broadcast_default = all
  title_at_bottom = True
  title_transmit_bg_color = "#241f31"
  title_receive_bg_color = "#3d3846"
  title_inactive_bg_color = "#241f31"
  enabled_plugins = LaunchpadBugURLHandler, LaunchpadCodeURLHandler, APTURLHandler, ActivityWatch
  title_use_system_font = False
  title_font = SauceCodePro Nerd Font 10
[keybindings]
  zoom_out = <Primary>minus
  zoom_normal = <Primary>0
  new_tab = <Alt>t
  cycle_next = ""
  cycle_prev = ""
  go_next = ""
  go_prev = ""
  go_up = <Super>j
  go_down = <Super>k
  go_left = <Super>h
  go_right = <Super>l
  rotate_cw = ""
  rotate_ccw = ""
  split_horiz = <Super>underscore
  split_vert = <Super>apostrophe
  close_term = <Super>w
  copy = <Primary><Shift>c
  paste = <Primary><Shift>v
  toggle_scrollbar = ""
  search = ""
  close_window = ""
  resize_up = <Shift><Super>KP_Subtract
  resize_down = <Shift><Super>KP_Add
  resize_left = <Super>KP_Subtract
  resize_right = <Super>KP_Add
  move_tab_right = ""
  move_tab_left = ""
  toggle_zoom = ""
  scaled_zoom = ""
  next_tab = ""
  prev_tab = ""
  reset = ""
  reset_clear = ""
  hide_window = ""
  group_all = ""
  ungroup_all = ""
  group_tab = ""
  ungroup_tab = ""
  new_window = ""
  new_terminator = ""
  insert_number = ""
  insert_padded = ""
  edit_window_title = ""
  edit_tab_title = ""
  edit_terminal_title = ""
  layout_launcher = ""
[profiles]
  [[default]]
    icon_bell = False
    background_darkness = 0.9
    background_type = transparent
    cursor_color = "#aaaaaa"
    font = SauceCodePro Nerd Font Propo Semi-Bold 10
    show_titlebar = False
    scrollbar_position = hidden
    scroll_on_keystroke = False
    scrollback_lines = 10000
    use_system_font = False
    use_theme_colors = True
    bold_is_bright = True
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
    [[[child1]]]
      type = Terminal
      parent = window0
[plugins]
